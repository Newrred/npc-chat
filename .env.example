# Local vLLM endpoint (recommended for free self-host setup)
NPC_CHARACTER_ID=default
NPC_LLM_BACKEND=vllm
NPC_BASE_URL=http://localhost:8000/v1
NPC_API_KEY=my-local-key
NPC_MODEL=Qwen/Qwen3-8B-AWQ
NPC_TIMEOUT=120
NPC_TEMP=0.4
NPC_TOP_P=1.0
NPC_TOP_K=20
NPC_PRESENCE_PENALTY=0.5
NPC_FREQUENCY_PENALTY=0.3
NPC_REPETITION_PENALTY=1.08
NPC_MAX_TOKENS=1024

# For GitHub Pages frontend access, set exact origin(s), comma-separated.
# Example: CORS_ORIGINS=https://yourid.github.io
CORS_ORIGINS=*
SESSION_TTL_SEC=3600
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=npc
REDIS_LOCK_TIMEOUT_SEC=30
REDIS_LOCK_BLOCKING_TIMEOUT_SEC=10

COMFY_ENABLED=false
COMFY_CONNECT=false
COMFY_BASE_URL=https://your-comfy.trycloudflare.com
COMFY_TIMEOUT=120
COMFY_CHARACTER_ID=npc-default
COMFY_STYLE_VERSION=v1
COMFY_GEN_COOLDOWN_TURNS=10
COMFY_GEN_MAX_PER_MINUTE=3
COMFY_GEN_MAX_INFLIGHT_PER_SESSION=1
COMFY_GEN_BACKOFF_SEC=30
COMFY_FORCE_REGEN_FACES=angry,crying,scared,excited
COMFY_CACHE_TTL_SEC=1800
